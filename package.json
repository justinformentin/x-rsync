{
  "name": "x-sync",
  "version": "0.1.1",
  "description": "A tiny rsync-style tool using SFTP + SHA-256 diffing. Push only changed files to remote servers.",
  "keywords": [
    "sftp",
    "deploy",
    "sync",
    "rsync",
    "ssh",
    "file-sync"
  ],
  "author": "Justin Formentin",
  "repository": {
    "type": "git",
    "url": "https://github.com/justinformentin/x-sync"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "x-sync": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "node scripts/build.js",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "cli-progress": "^3.12.0",
    "commander": "^14.0.2",
    "dotenv": "^17.2.3",
    "minimatch": "^10.1.1",
    "ssh2-sftp-client": "^10.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ssh2-sftp-client": "^9.0.6",
    "esbuild": "^0.27.0",
    "typescript": "^5.6.0"
  }
}
